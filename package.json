{
  "name": "@enke.dev/lit-utils",
  "version": "0.4.4",
  "license": "MIT",
  "description": "Custom utils, converters and directives for the lit library.",
  "author": {
    "name": "David Enke",
    "email": "david@enke.dev"
  },
  "files": [
    "lib"
  ],
  "keywords": [],
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint",
    "test": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" NODE_NO_WARNINGS=1 jest",
    "build": "tsc --project tsconfig.build.json",
    "docs:dev:readmes": "typedoc --watch",
    "docs:dev:website": "vitepress dev docs",
    "docs:dev": "run-p -ns docs:dev:*",
    "docs:build:readmes": "typedoc",
    "docs:build:website": "vitepress build docs",
    "docs": "run-s docs:build:*"
  },
  "peerDependencies": {
    "@lit-labs/router": "^0.1.4",
    "lit": "^3",
    "urlpattern-polyfill": "^10"
  },
  "devDependencies": {
    "@awmottaz/prettier-plugin-void-html": "2.1.0",
    "@enke.dev/lint": "0.13.3",
    "@esm-bundle/chai": "4.3.4-fix.0",
    "@open-wc/semantic-dom-diff": "0.21.0",
    "@open-wc/testing": "5.0.0",
    "@open-wc/testing-helpers": "3.0.1",
    "@tsconfig/strictest": "2.0.8",
    "@types/mocha": "10.0.10",
    "@types/node": "24.13.3",
    "cross-env": "10.1.0",
    "eslint": "10.7.0",
    "eslint-formatter-junit": "9.0.1",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-junit": "17.0.0",
    "jiti": "2.7.0",
    "npm-run-all": "4.1.5",
    "pagefind": "1.5.2",
    "playwright-chromium": "1.61.1",
    "prettier": "3.9.5",
    "sinon": "22.0.0",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typedoc": "0.28.20",
    "typedoc-plugin-markdown": "4.12.0",
    "typedoc-vitepress-theme": "1.1.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite-plugin-mkcert": "2.1.0",
    "vitepress": "2.0.0-alpha.18",
    "vitepress-plugin-pagefind": "0.4.22"
  },
  "overrides": {
    "eslint": "$eslint",
    "prettier": "$prettier"
  },
  "bugs": "https://github.com/enke-dev/lit-utils/issues",
  "homepage": "https://enke-dev.github.io/lit-utils",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enke-dev/lit-utils.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "playwright-chromium@1.61.1": true,
    "unrs-resolver@1.12.2": true
  }
}
